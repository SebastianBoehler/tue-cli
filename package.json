{
  "name": "tue-cli",
  "version": "0.1.0",
  "description": "CLI for recurring WSI MPC workflows (pool machine discovery, VNC lifecycle, SSH tunneling)",
  "type": "module",
  "license": "MIT",
  "files": [
    "src",
    "README.md",
    "LICENSE",
    ".env.example"
  ],
  "bin": {
    "tue": "./src/index.ts"
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "tue": "bun run src/index.ts",
    "test": "bun test",
    "check": "bunx tsc --noEmit",
    "lint": "eslint src test --ext .ts",
    "lint:fix": "eslint src test --ext .ts --fix",
    "prepare": "husky install",
    "link:global": "bun link"
  },
  "devDependencies": {
    "@inquirer/prompts": "^7.8.6",
    "@typescript-eslint/eslint-plugin": "^8.46.0",
    "@typescript-eslint/parser": "^8.46.0",
    "@types/node": "^25.3.3",
    "eslint": "^9.37.0",
    "husky": "^9.1.7",
    "picocolors": "^1.1.1",
    "typescript": "^5.6.3"
  }
}
