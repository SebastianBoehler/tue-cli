# Copy to .env and adjust locally
TUE_USER=your_wsi_username
# Outside WSI network: sshgw.cs.uni-tuebingen.de
# Inside university network/VPN: cgcontact.cs.uni-tuebingen.de
TUE_GATEWAY=sshgw.cs.uni-tuebingen.de
TUE_MACHINE=cgpool1907
TUE_VNC_VM=
TUE_CUDA_VISIBLE_DEVICES=

# Optional default
TUE_DRY_RUN=false

# Optional build defaults used by `tue build`
# Allowed remote-root prefixes:
#   ~/..., /home/..., /graphics/scratch2/students/..., /graphics/scratch3/staff/..., /ceph/..., /var/tmp/...
TUE_REMOTE_ROOT=~/exercise00
TUE_BUILD_CMD=cmake -S . -B build -DCMAKE_BUILD_TYPE=Release && cmake --build build -j
TUE_BUILD_PRESET=release
TUE_ARTIFACT_PATH=build
TUE_BUILD_OUTPUT=./.tue-artifacts
TUE_PROJECT_NAME=
TUE_KEEP_REMOTE=false
TUE_NO_DOWNLOAD=false
